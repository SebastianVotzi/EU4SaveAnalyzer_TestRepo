<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – EU4 Save Analyzer</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark" id="main-navbar">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">
            <i class="bi bi-globe2 me-2"></i>EU4 Save Analyzer
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
                       href="/">
                        <i class="bi bi-house-fill me-1"></i>Saves
                    </a>
                </li>
                @if (ViewBag.SaveId != null)
                {
                    int sid = (int)ViewBag.SaveId;
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Economy" ? "active" : "")"
                           href="/Economy?saveId=@sid">
                            <i class="bi bi-currency-euro me-1"></i>Wirtschaft
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Military" ? "active" : "")"
                           href="/Military?saveId=@sid">
                            <i class="bi bi-shield-fill me-1"></i>Militär
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Spending" ? "active" : "")"
                           href="/Spending?saveId=@sid">
                            <i class="bi bi-pie-chart-fill me-1"></i>Spending
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Mana" ? "active" : "")"
                           href="/Mana?saveId=@sid">
                            <i class="bi bi-stars me-1"></i>Mana
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Wars" ? "active" : "")"
                           href="/Wars?saveId=@sid">
                            <i class="bi bi-fire me-1"></i>Kriege
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Ranking" ? "active" : "")"
                           href="/Ranking?saveId=@sid">
                            <i class="bi bi-trophy-fill me-1"></i>Ranking
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PlayerComparison" ? "active" : "")"
                           href="/PlayerComparison?saveId=@sid">
                            <i class="bi bi-people-fill me-1"></i>Spieler
                        </a>
                    </li>
                }
            </ul>
            @if (ViewBag.SaveId != null)
            {
                <span class="navbar-text text-warning">
                    <i class="bi bi-calendar3 me-1"></i>@ViewBag.GameDate
                </span>
            }
        </div>
    </div>
</nav>

<!-- Main Content -->
<main class="container-fluid py-4">
    @RenderBody()
</main>

<!-- Footer -->
<footer class="footer mt-auto py-3">
    <div class="container text-center">
        <span class="text-muted">EU4 Save Analyzer &copy; @DateTime.Now.Year — 4IT SEW Projekt</span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
